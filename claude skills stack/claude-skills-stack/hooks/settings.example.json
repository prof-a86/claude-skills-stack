{
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/degradation-monitor.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/session-close.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/compact-tracker.sh"
          }
        ]
      }
    ]
  },
  "env": {
    "CLAUDE_PROJECT_STATE_PATH": ""
  }
}
